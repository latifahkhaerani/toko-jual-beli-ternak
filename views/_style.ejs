<!-- Bootstrap 5 CSS -->
<link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>

<!-- Google Fonts -->
<link
  href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap"
  rel="stylesheet"
/>

<!-- Icon -->
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
/>

<style>
  :root {
    --bg-color: #f4f1de;
    --primary-yellow: #ffde4d;
    --accent-pink: #ff6b6b;
    --accent-green: #80ed99;
    --accent-blue: #64b5f6;
    --dark-border: #1a1a1a;
  }

  body {
    background-color: var(--bg-color);
    font-family: "Space Grotesk", sans-serif;
  }

  .content {
    padding: 20px;
  }

  /* ================= NAVBAR ================= */
  .neo-navbar {
    padding: 20px;
  }
  .neo-brand {
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--dark-border) !important;
    text-transform: uppercase;
    letter-spacing: -1px;
    padding: 5px 10px;
    border: 3px solid transparent;
    transition: all 0.2s ease;
  }

  .neo-brand:hover {
    background-color: var(--accent-pink);
    border-color: var(--dark-border);
    transform: rotate(-2deg) scale(1.05);
    box-shadow: 4px 4px 0px var(--dark-border);
  }

  .btn-neo {
    font-weight: 700;
    text-transform: uppercase;
    border: 3px solid var(--dark-border) !important;
    border-radius: 0px !important;
    padding: 8px 20px !important;
    transition: all 0.15s ease;
  }

  .btn-neo-login {
    background-color: #ffffff;
    color: var(--dark-border);
    margin-right: 0px;
    box-shadow: 4px 4px 0px var(--dark-border);
  }

  .btn-neo-login:hover {
    background-color: var(--dark-border);
    color: #ffffff;
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px var(--dark-border);
  }

  .btn-neo-register {
    background-color: var(--primary-yellow);
    color: var(--dark-border);
    box-shadow: 4px 4px 0px var(--dark-border);
  }

  .btn-neo-register:hover {
    background-color: #ffffff;
    transform: translate(-4px, -4px) rotate(1deg);
    box-shadow: 8px 8px 0px var(--dark-border);
  }

  /* ================= HERO ================= */

  .hero-box {
    border: 4px solid var(--dark-border);
    background: #fff;
    box-shadow: 8px 8px 0px var(--dark-border);
  }

  /* ================= CARD ================= */

  .neo-card {
    border: 4px solid var(--dark-border);
    border-radius: 0;
    overflow: hidden;
    background: white;
    box-shadow: 8px 8px 0px var(--dark-border);
    transition: all 0.2s ease;
    height: 100%;
  }

  .neo-card:hover {
    transform: translate(-6px, -6px) rotate(-1deg);
    box-shadow: 14px 14px 0px var(--dark-border);
  }

  .neo-card img {
    height: 220px;
    object-fit: cover;
    border-bottom: 4px solid var(--dark-border);
  }

  .card-title {
    font-weight: 700;
    font-size: 1.2rem;
  }

  .animal-tag {
    display: inline-block;
    padding: 6px 12px;
    border: 3px solid var(--dark-border);
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 15px;
  }

  .tag-yellow {
    background: var(--primary-yellow);
  }

  .tag-pink {
    background: var(--accent-pink);
  }

  .tag-green {
    background: var(--accent-green);
  }

  .tag-blue {
    background: var(--accent-blue);
  }

  .price {
    font-size: 1.4rem;
    font-weight: 700;
  }

  .btn-buy {
    width: 100%;
    border: 3px solid var(--dark-border);
    border-radius: 0;
    background: var(--primary-yellow);
    font-weight: 700;
    padding: 10px;
    box-shadow: 4px 4px 0px var(--dark-border);
    transition: all 0.15s ease;
  }

  .btn-buy:hover {
    transform: translate(-3px, -3px);
    background: var(--accent-pink);
    box-shadow: 7px 7px 0px var(--dark-border);
  }

  .btn-buy:active {
    transform: translate(3px, 3px);
    box-shadow: 0px 0px 0px var(--dark-border);
  }

  /* ICON */
  .neo-cart-icon {
    font-size: 1.5rem;
    color: var(--dark-border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary-yellow);
    padding: 2px;
    border: 3px solid var(--dark-border);

    box-shadow: 4px 4px 0px var(--dark-border);
    transition: 0.15s ease;
  }

  .neo-cart-icon:hover {
    transform: translate(-3px, -3px);
    background: var(--accent-pink);
  }

  /* ================= ANIMATION ================= */

  @keyframes slideInDown {
    0% {
      transform: translateY(-60px) scale(0.95);
      opacity: 0;
    }

    100% {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }
</style>
