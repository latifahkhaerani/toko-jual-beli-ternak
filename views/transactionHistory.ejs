<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sayap Cinta Farm - Riwayat Transaksi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-color: #f4f1de;
            /* Warna koran mentah */
            --primary-yellow: #ffde4d;
            /* Kuning terang */
            --accent-purple: #9b5de5;
            /* Ungu pop khusus variasi finansial/transaksi */
            --accent-pink: #ff6b6b;
            /* Pink pop */
            --accent-blue: #3a86ff;
            /* Biru pop */
            --dark-border: #1a1a1a;
            /* Border hitam pekat */
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Space Grotesk', sans-serif;
            padding-bottom: 50px;
        }

        /* --- TITLE STYLE --- */
        .page-title {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 2rem;
            letter-spacing: -1px;
            display: inline-block;
            background-color: var(--accent-purple);
            /* Menggunakan aksen ungu pop */
            color: #ffffff;
            padding: 8px 20px;
            border: 4px solid var(--dark-border);
            box-shadow: 6px 6px 0px var(--dark-border);
            transform: rotate(-0.5deg);
            margin-bottom: 30px;
        }

        /* --- BUTTONS STYLE --- */
        .btn-neo-back {
            font-weight: 700;
            text-transform: uppercase;
            background-color: #ffffff;
            color: var(--dark-border) !important;
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            padding: 10px 20px;
            box-shadow: 4px 4px 0px var(--dark-border);
            transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-decoration: none;
            display: inline-block;
        }

        .btn-neo-back:hover {
            background-color: var(--primary-yellow);
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--dark-border);
        }

        .btn-neo-back:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px var(--dark-border);
        }

        /* --- TABLE NEORUTALISM STYLE --- */
        .table-responsive-neo {
            background-color: #ffffff;
            border: 4px solid var(--dark-border);
            box-shadow: 12px 12px 0px var(--dark-border);
            margin-top: 20px;

            /* Animasi Fade In Pop */
            opacity: 0;
            transform: translateY(20px);
            animation: tablePopUp 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        .table-neo {
            margin-bottom: 0px !important;
        }

        .table-neo thead th {
            background-color: var(--primary-yellow) !important;
            color: var(--dark-border) !important;
            font-weight: 700;
            text-transform: uppercase;
            border-bottom: 4px solid var(--dark-border) !important;
            border-right: 2px solid var(--dark-border);
            padding: 15px;
        }

        .table-neo tbody td {
            border-bottom: 3px solid var(--dark-border) !important;
            border-right: 2px solid var(--dark-border);
            padding: 15px;
            font-weight: 500;
            vertical-align: middle;
            color: var(--dark-border);
        }

        .table-neo tbody tr:last-child td {
            border-bottom: none !important;
        }

        .table-neo tbody tr:hover {
            background-color: rgba(155, 93, 229, 0.08);
            /* Efek highlight baris warna ungu soft */
        }

        /* Kustomisasi Kode Resi Brutal */
        .neo-receipt-code {
            font-family: 'Space Grotesk', monospace;
            background-color: var(--primary-yellow);
            color: var(--dark-border);
            font-weight: 700;
            padding: 4px 8px;
            border: 2px solid var(--dark-border);
            box-shadow: 2px 2px 0px var(--dark-border);
            display: inline-block;
        }

        /* Teks Alergi Data Terhapus */
        .text-deleted-animal {
            color: var(--accent-pink);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.9rem;
        }

        /* --- KEYFRAMES ANIMATION --- */
        @keyframes tablePopUp {
            0% {
                opacity: 0;
                transform: translateY(20px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="container mt-5">

        <div
            class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-3">
            <div>
                <h1 class="page-title">Riwayat Pembelian Ternak</h1>
            </div>
            <div>
                <a href="/stock" class="btn-neo-back">← Kembali ke Marketplace</a>
            </div>
        </div>

        <div class="table-responsive table-responsive-neo">
            <table class="table table-neo align-middle">
                <thead>
                    <tr>
                        <th style="width: 60px; text-align: center;">No.</th>
                        <th>Nomor Resi</th>
                        <th>Kode Ternak</th>
                        <th>Nama Hewan</th>
                        <th>Jenis</th>
                        <th>Total Bayar</th>
                        <th>Tanggal Transaksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (transactions.length===0) { %>
                        <tr>
                            <td colspan="7" class="text-center py-5 fw-bold text-muted">
                                Anda belum pernah melakukan transaksi pembelian hewan ternak.
                            </td>
                        </tr>
                        <% } else { %>
                            <% transactions.forEach((tx, index)=> { %>
                                <tr>
                                    <td class="fw-bold text-center">
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <span class="neo-receipt-code">
                                            <%= tx.receiptNumber %>
                                        </span>
                                    </td>
                                    <td class="fw-bold">
                                        <%= tx.Livestock ? tx.Livestock.animalCode : '-' %>
                                    </td>
                                    <td class="fw-bold text-uppercase">
                                        <% if (tx.Livestock) { %>
                                            <%= tx.Livestock.name %>
                                                <% } else { %>
                                                    <span class="text-deleted-animal">Data Hewan Telah Dihapus</span>
                                                    <% } %>
                                    </td>
                                    <td>
                                        <%= tx.Livestock ? tx.Livestock.type : '-' %>
                                    </td>
                                    <td class="fw-bold text-success" style="font-size: 1.05rem;">
                                        <%= formatRupiah(tx.totalPaid) %>
                                    </td>
                                    <td class="small fw-medium">
                                        <%= new Date(tx.createdAt).toLocaleDateString('id-ID', { weekday: 'long' ,
                                            year: 'numeric' , month: 'long' , day: 'numeric' , hour: '2-digit' ,
                                            minute:'2-digit' }) %> WIB
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } %>
                </tbody>
            </table>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>