<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome</title>
    <%- include('_style') %>
  </head>

  <body>
    <!-- NAVBAR -->
    <%- include('_navbar') %>

    <div class="container mt-3">
      <!-- HERO -->
      <div class="content mt-5 p-4 text-center hero-box">
        <h1 class="fw-bold">Marketplace Ternak Modern 🐓</h1>
        <% if (userRole==='Seller') { %>
         <p>
          Jual ternak terbaikmu di sini!
        </p>
        <% } else { %>
          <p>
            Pilih ternak terbaik langsung dari peternakan terpercaya!
          </p>
        <%  } %>
      </div>

      <!-- CARD SECTION -->
      <div class="row mt-5 g-4">
        <!-- CARD 1 -->
         <% products.forEach(p => { %>
          <div class="col-lg-3 col-md-6">
            <div class="card neo-card">
              <img
                src="https://images.unsplash.com/photo-1548550023-2bdb3c5beed7?q=80&w=1200&auto=format&fit=crop"
                alt="Ayam"
              />
  
              <div class="card-body">
                <%
                  let tagClass = '';

                  if (p.type === 'Domba') {
                    tagClass = 'tag-yellow';
                  } else if (p.type === 'Sapi') {
                    tagClass = 'tag-pink';
                  } else {
                    tagClass = 'tag-blue';
                  }
                %>

                <span class="animal-tag <%= tagClass %>">
                  <%= p.type %>
                </span>
  
                <h5 class="card-title"><%= p.name %></h5>
  
                <p>
                  Ayam sehat dengan kualitas terbaik untuk kebutuhan ternak
                  modern.
                </p>
  
                <div
                  class="d-flex justify-content-between align-items-center mb-3"
                >
                  <span class="price"><%= formatRupiah(p.price) %></span>
                  
                </div>
  
                <button class="btn-buy">
                  <a href="/stock"></a>
                  ADD TO CART</button>
              </div>
            </div>
          </div>
          
         <% }); %>

