<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome</title>
  <%- include('_style') %>
</head>

<body>
  <!-- NAVBAR -->
  <%- include('_navbar') %>

    <div class="container mt-3">
      <!-- HERO -->
      <div class="content mt-5 p-4 text-center hero-box">
        <h1 class="fw-bold">Marketplace Ternak Modern </h1>
        <% if (userRole==='Seller' ) { %>
          <p>
            Jual ternak terbaikmu di sini!
          </p>
          <% } else { %>
            <p>
              Pilih ternak terbaik langsung dari peternakan terpercaya!
            </p>
            <% } %>
      </div>

      <!-- notif -->
    <% if (mustLogin) { %>
    <div id="notification"
      style="background-color: #f8d7da; color: #721c24; padding: 12px; border: 1px solid #f5c6cb; border-radius: 5px; margin-bottom: 15px; width: fit-content; font-weight: bold; margin-top:30px; position: fixed; right: 20px;">
      ✗ <%= mustLogin %>
    </div>
    <% } %>
      <!-- CARD SECTION -->
      <div class="row mt-5 g-4">

  <% if (userRole === 'Seller' && products.length === 0) { %>
    <a href="/stock/add" class="btn-neo-action btn-add-ternak d-flex justify-content-center">
      + Tambah Hewan Ternak Baru
    </a>
  <% } %>

  <% products.forEach(p => { %>
    <div class="col-lg-3 col-md-6">

      <div class="card neo-card">

        <!-- GAMBAR BISA DIKLIK -->
        <a href="/stock/<%= p.id %>">
          <img src="<%= p.imageUrl %>" alt="<%= p.name %>">
        </a>

        <div class="card-body">

          <% let tagClass = ''; %>
          <% if (p.type === 'Domba') { %>
            <% tagClass = 'tag-yellow'; %>
          <% } else if (p.type === 'Sapi') { %>
            <% tagClass = 'tag-pink'; %>
          <% } else { %>
            <% tagClass = 'tag-blue'; %>
          <% } %>

          <a href="/stock/<%= p.id %>" class="animal-tag <%= tagClass %>">
            <%= p.type %>
          </a>

          <!-- JUDUL BISA DIKLIK -->
          <a href="/stock/<%= p.id %>">
            <h5 class="card-title">
              <%= p.name %>
            </h5>
          </a>

          <p>
            <%= p.description %>
          </p>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="price">
              <%= formatRupiah(p.price) %>
            </span>
          </div>

          <% if (userRole === 'Seller') { %>

            <button class="btn-buy">
              <a
                style="text-decoration:none; color:black;"
                href="/stock"
              >
                KELOLA KANDANG SAYA
              </a>
            </button>

          <% } else { %>

            <button class="btn-buy">
              <a
                style="text-decoration:none; color:black; font-weight:700;"
                href="/stock/add-to-cart/<%= p.id %>"
              >
                🛒 ADD TO CART
              </a>
            </button>

          <% } %>

        </div>
      </div>

    </div>
  <% }) %>
    
</div>

    </div>
<%- include('_footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
  setTimeout(() => {
    const notif = document.getElementById("notification");

    if (notif) {
      notif.remove();
    }
  }, 3000); 
</script>
</body>

</html>