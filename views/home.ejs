<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sayap Cinta Farm - Neobrutalism Navbar</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts: Space Grotesk (Sangat cocok untuk tema Neobrutalisme) -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-color: #f4f1de;
            /* Warna background halaman khas koran kuno/mentah */
            --primary-yellow: #ffde4d;
            /* Kuning terang khas neobrutalisme */
            --accent-pink: #ff6b6b;
            /* Warna pink/merah pop */
            --dark-border: #1a1a1a;
            /* Border hitam pekat */
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Space Grotesk', sans-serif;
            padding: 20px;
        }

        /* --- NEOBRUTALISM NAVBAR STYLE --- */
        .neo-navbar {
            background-color: #ffffff;
            border: 4px solid var(--dark-border);
            /* Hard shadow tanpa blur */
            box-shadow: 8px 8px 0px 0px var(--dark-border);
            padding: 15px 25px;
            border-radius: 0px;
            /* Neobrutalisme menghindari rounded corner yang halus */

            /* Animasi masuk saat page load */
            transform: translateY(-50px);
            opacity: 0;
            animation: slideInDown 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        /* Logo Brand */
        .neo-brand {
            font-weight: 700;
            font-size: 1.6rem;
            color: var(--dark-border) !important;
            text-transform: uppercase;
            letter-spacing: -1px;
            padding: 5px 10px;
            border: 3px solid transparent;
            transition: all 0.2s ease;
        }

        /* Animasi hover pada Logo */
        .neo-brand:hover {
            background-color: var(--accent-pink);
            border-color: var(--dark-border);
            transform: rotate(-2deg) scale(1.05);
            box-shadow: 4px 4px 0px var(--dark-border);
        }

        /* Tombol Auth Umum */
        .btn-neo {
            font-weight: 700;
            text-transform: uppercase;
            border: 3px solid var(--dark-border) !important;
            border-radius: 0px !important;
            padding: 8px 20px !important;
            transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
        }

        /* Variasi Tombol Login (Putih) */
        .btn-neo-login {
            background-color: #ffffff;
            color: var(--dark-border);
            margin-right: 15px;
            box-shadow: 4px 4px 0px var(--dark-border);
        }

        .btn-neo-login:hover {
            background-color: var(--dark-border);
            color: #ffffff;
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--dark-border);
        }

        .btn-neo-login:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px var(--dark-border);
        }

        /* Variasi Tombol Register (Kuning Menyala) */
        .btn-neo-register {
            background-color: var(--primary-yellow);
            color: var(--dark-border);
            box-shadow: 4px 4px 0px var(--dark-border);
        }

        .btn-neo-register:hover {
            background-color: #ffffff;
            transform: translate(-4px, -4px) rotate(1deg);
            box-shadow: 8px 8px 0px var(--dark-border);
        }

        .btn-neo-register:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px var(--dark-border);
        }

        /* --- KEYFRAMES ANIMATION --- */
        @keyframes slideInDown {
            0% {
                transform: translateY(-60px) scale(0.95);
                opacity: 0;
            }

            100% {
                transform: translateY(0) scale(1);
                opacity: 1;
            }
        }
    </style>
</head>

<body>

    <div class="container mt-3">
        <!-- Navbar Start -->
        <nav class="navbar neo-navbar">
            <div class="container-fluid d-flex justify-content-between align-items-center">

                <!-- Kiri: Logo Tulisan -->
                <a class="navbar-brand neo-brand" href="#">
                    Sayap Cinta Farm
                </a>

                <!-- Kanan: Login & Register -->
                <div class="d-flex auth-buttons">
                    <a href="/login" class="btn btn-neo btn-neo-login">Login</a>
                    <a href="/register" class="btn btn-neo btn-neo-register">Register</a>
                </div>

            </div>
        </nav>
        <!-- Navbar End -->

        <!-- Contoh Konten Tambahan Supaya Efeknya Terlihat Sempurna -->
        <div class="mt-5 p-4 text-center"
            style="border: 4px solid #1a1a1a; background: #fff; box-shadow: 8px 8px 0 px #1a1a1a;">
            <h1 class="fw-bold">Selamat Datang di Peternakan Modern</h1>
            <p>Klik tombol di navbar untuk melihat efek animasi benturan (*spring/pop*) khas Neobrutalisme.</p>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>