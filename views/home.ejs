<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to Kandangi</title>
  <%- include('_style') %>
</head>

<body>
  <!-- NAVBAR -->
  <%- include('_navbar') %>

    <div class="container mt-3">
      <!-- HERO -->
      <div class="content mt-5 p-4 text-center hero-box">
        <h1 class="fw-bold">Marketplace Ternak Modern </h1>
        <% if (userRole==='Seller' ) { %>
          <p>
            Jual ternak terbaikmu di sini!
          </p>
          <% } else { %>
            <p>
              Pilih ternak terbaik langsung dari peternakan terpercaya!
            </p>
            <% } %>
      </div>

      <!-- CARD SECTION -->
      <div class="row mt-5 g-4">

        <% if (userRole==='Seller' && products.length===0) { %>
          <a href="/stock/add" class="btn-neo-action btn-add-ternak d-flex justify-content-center"> + Tambah Hewan
            Ternak Baru</a>
          <% } %>


            <% products.forEach(p=> { %>
              <div class="col-lg-3 col-md-6">
  <a href="/stock/<%= p.id %>" class="card-link">
    <div class="card neo-card">
      <img src="<%= p.imageUrl %>" />

      <div class="card-body">
        <% let tagClass='' ; if (p.type==='Domba' ) { tagClass='tag-yellow' ; } else if (p.type==='Sapi' ) {
        tagClass='tag-pink' ; } else { tagClass='tag-blue' ; } %>

        <span class="animal-tag <%= tagClass %>">
          <%= p.type %>
        </span>

        <h5 class="card-title">
          <%= p.name %>
        </h5>

        <p>
          <%= p.description %>
        </p>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="price">
            <%= formatRupiah(p.price) %>
          </span>
        </div>

        <% if (userRole==='Seller') {%>
          <button
            class="btn-buy"
            onclick="event.preventDefault(); window.location.href='/stock'"
          >
            KELOLA KANDANG SAYA
          </button>

        <% } else if (userRole==='Buyer') { %>

          <button
            class="btn-buy"
            onclick="event.preventDefault(); window.location.href='/stock/buy/<%= p.id %>'"
          >
            BELI
          </button>

        <% } else { %>

          <button
            class="btn-buy"
            onclick="event.preventDefault(); window.location.href='/login'"
          >
            BELI
                    </button>

                  <% } %>
                </div>
              </div>
            </a>
          </div>

              <% }); %>
      </div>

    </div>

    
    <%- include('_footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
</body>

</html>